server {
    listen 80;
    server_name {{ nginx_server_name }};

    # Serve the application under a base path (e.g. /stravaapps) and proxy
    # to the local Gunicorn instance on port 5000. Requests to
    # {{ base_path }}/... are forwarded with the prefix stripped.
    location {{ base_path }}/ {
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        # Let the upstream receive the path without the base prefix.
        proxy_pass http://127.0.0.1:5000/;
        proxy_redirect off;
    }

    # Health endpoint exposed at the root of the base path
    location = {{ base_path }}/health {
        proxy_pass http://127.0.0.1:5000/health;
    }

    # Redirect to HTTPS if TLS is enabled and certs are present
    {% if enable_tls and nginx_server_name != 'localhost' %}
    return 301 https://$host$request_uri;
    {% endif %}
}

{% if enable_tls %}
server {
    listen 443 ssl;
    server_name {{ nginx_server_name }};

    ssl_certificate {{ ssl_cert_path }};
    ssl_certificate_key {{ ssl_key_path }};
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;

    location / {
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_pass http://127.0.0.1:5000;
        proxy_redirect off;
    }

    location = /health {
        proxy_pass http://127.0.0.1:5000/health;
    }
}
{% endif %}