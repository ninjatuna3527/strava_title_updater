# System SMTP relay configuration generated by Ansible
defaults
auth on
{% if smtp_security == 'starttls' %}
tls on
tls_starttls on
tls_trust_file /etc/ssl/certs/ca-certificates.crt
{% elif smtp_security == 'ssl' %}
tls on
tls_starttls off
tls_trust_file /etc/ssl/certs/ca-certificates.crt
{% else %}
tls off
{% endif %}
logfile /var/log/msmtp.log
aliases /etc/aliases

account default
host {{ smtp_host }}
port {{ smtp_port }}
from {{ smtp_sender }}
user {{ smtp_user }}
passwordeval "cat /etc/msmtp-password"
