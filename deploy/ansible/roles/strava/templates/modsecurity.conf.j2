# ModSecurity and OWASP CRS configuration generated by Ansible
Include /etc/nginx/modsecurity.conf

SecRuleEngine {{ nginx_waf_mode }}
SecAuditEngine RelevantOnly
SecAuditLogRelevantStatus "^(?:5|4(?!04))"
SecAuditLogParts ABIJDEFHZ
SecAuditLogType Serial
SecAuditLog {{ nginx_waf_audit_log }}

Include /etc/modsecurity/crs/crs-setup.conf
Include /etc/modsecurity/crs/REQUEST-900-EXCLUSION-RULES-BEFORE-CRS.conf

SecAction "id:1000001,phase:1,pass,nolog,setvar:tx.paranoia_level={{ nginx_waf_paranoia_level }},setvar:tx.executing_paranoia_level={{ nginx_waf_paranoia_level }},setvar:tx.inbound_anomaly_score_threshold={{ nginx_waf_inbound_anomaly_threshold }},setvar:tx.outbound_anomaly_score_threshold={{ nginx_waf_outbound_anomaly_threshold }}"

Include /usr/share/modsecurity-crs/rules/*.conf
Include /etc/modsecurity/crs/RESPONSE-999-EXCLUSION-RULES-AFTER-CRS.conf
