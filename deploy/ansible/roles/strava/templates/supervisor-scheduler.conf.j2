[program:{{ scheduler_supervisor_program }}]
command={{ deploy_path }}/venv/bin/python -m src.scheduler
directory={{ deploy_path }}
user={{ ansible_user }}
autostart=true
autorestart=true
stderr_logfile=/var/log/{{ scheduler_supervisor_program }}_err.log
stdout_logfile=/var/log/{{ scheduler_supervisor_program }}.log
environment=PATH="{{ deploy_path }}/venv/bin:%(ENV_PATH)s",PYTHONUNBUFFERED="1"
