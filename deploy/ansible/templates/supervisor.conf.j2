[program:{{ supervisor_program }}]
directory={{ deploy_path }}
user={{ ansible_user }}
command=/bin/bash -lc '{{ deploy_path }}/venv/bin/gunicorn -w ${GUNICORN_WORKERS:-3} -b 127.0.0.1:5000 wsgi:app --config {{ deploy_path }}/gunicorn.conf.py'
autostart=true
autorestart=true
stopsignal=TERM
stdout_logfile=/var/log/{{ supervisor_program }}.log
stderr_logfile=/var/log/{{ supervisor_program }}_err.log
environment=PATH="{{ deploy_path }}/venv/bin:%(ENV_PATH)s"
priority=999
