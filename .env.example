# Example environment variables (copy to .env or mount as .secure/credentials.txt)
# STRAVA_CLIENT_ID=22030
# STRAVA_CLIENT_SECRET=your_secret_here
POLL_INTERVAL_SECONDS=3600

# Optional: configure callback hostname and scheme for OAuth redirect
# Use when your public host differs from the container's BASE_URL
CALLBACK_HOSTNAME=example.com
CALLBACK_SCHEME=https

# Copy this to .env and fill in values
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
DB_PATH=./data/strava.db
BASE_URL=http://localhost:5000

# Optional: generate funny excuse titles with OpenAI instead of random characters
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
